{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(brew bundle:*)",
      "Bash(brew leaves:*)",
      "Bash(brew list:*)",
      "Bash(mkdir -p ~/dotfiles/z/*)",
      "Bash(find ~/dotfiles/z *)"
    ]
  }
}
