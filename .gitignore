### ignore all ###
/*
/.**

### not ignore ###
!/iterm2
!/karabiner
!/raycast
!/mac
!/symlinks
!/vscode
!/setup.sh
!/link.sh
!/starship.toml

!/README.md
!/LICENCE
!.gitignore
!/Brewfile.notes.md

# ----------------------------------
# Claude Code 関連
# ----------------------------------
# 調査・計画用作業ディレクトリ
/z/

# プロジェクト専用設定はGit管理する
!/.claude/
!/.claude/settings.json
/.claude/settings.local.json

# .claudeディレクトリ配下は一旦すべて無視する
/symlinks/.claude/*

# ただし、自分で管理したいディレクトリ・ファイルだけは例外（!）としてGit管理に含める
!/symlinks/.claude/skills/
!/symlinks/.claude/rules/
!/symlinks/.claude/prompts/
!/symlinks/.claude/hooks/
!/symlinks/.claude/icons/
!/symlinks/.claude/settings.json

# (各ディレクトリの中身はすべて追跡させる)
!/symlinks/.claude/skills/**
!/symlinks/.claude/rules/**
!/symlinks/.claude/prompts/**
!/symlinks/.claude/hooks/**
!/symlinks/.claude/icons/**
