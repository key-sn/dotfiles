{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAX_THINKING_TOKENS": "31999"
  },
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run test *)",
      "Read(~/.zshrc)",
      "Read",
      "WebFetch",
      "WebSearch",
      "Bash(ls *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(git push *)"
    ]
  },
  "model": "opusplan",
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/scripts/statusline-command.sh"
  }
}
